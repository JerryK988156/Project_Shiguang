# 数据库连接
OCEANBASE_URL=jdbc:mysql://127.0.0.1:2881/shiguang_plan?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Shanghai
OCEANBASE_USERNAME=root
OCEANBASE_PASSWORD=
OCEANBASE_BOOTSTRAP_URL=jdbc:mysql://127.0.0.1:2881/?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Shanghai
OCEANBASE_DATABASE=shiguang_plan

# 数据库初始化
DB_VERIFY_ON_STARTUP=true
DB_AUTO_INIT_ON_STARTUP=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TYPE=redis

# AI LLM 配置 (请替换为你的真实 API Key)
AI_LLM_API_BASE_URL=https://api.deepseek.com
AI_LLM_API_KEY=your_api_key_here
AI_LLM_MODEL=deepseek-v4-pro
