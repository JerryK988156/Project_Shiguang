#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
PROPERTIES_FILE="$SCRIPT_DIR/.mvn/wrapper/maven-wrapper.properties"

if [ ! -f "$PROPERTIES_FILE" ]; then
  echo "缺少 $PROPERTIES_FILE" >&2
  exit 1
fi

DISTRIBUTION_URL="$(grep '^distributionUrl=' "$PROPERTIES_FILE" | sed 's/^distributionUrl=//')"

if [ -z "$DISTRIBUTION_URL" ]; then
  echo "maven-wrapper.properties 未配置 distributionUrl" >&2
  exit 1
fi

ZIP_NAME="${DISTRIBUTION_URL##*/}"
DIST_NAME="${ZIP_NAME%.zip}"
EXPECTED_DIR="${DIST_NAME%-bin}"
CACHE_ROOT="${HOME}/.m2/wrapper/dists"
DOWNLOAD_DIR="${CACHE_ROOT}/${DIST_NAME}"
ZIP_PATH="${DOWNLOAD_DIR}/${ZIP_NAME}"
MAVEN_HOME="${DOWNLOAD_DIR}/${EXPECTED_DIR}"
MVN_CMD="${MAVEN_HOME}/bin/mvn"

if [ ! -x "$MVN_CMD" ]; then
  mkdir -p "$DOWNLOAD_DIR"
  if [ ! -f "$ZIP_PATH" ]; then
    curl -fsSL "$DISTRIBUTION_URL" -o "$ZIP_PATH"
  fi
  unzip -oq "$ZIP_PATH" -d "$DOWNLOAD_DIR"
fi

exec "$MVN_CMD" "$@"
